# Postgres connection string.
# Local: `docker compose up -d` then use the line below.
# Prod:  Neon free-tier connection string (recommended).
DATABASE_URL="postgres://parakhi:parakhi@localhost:5432/parakhi"

OPENAI_API_KEY=""
LLM_PROVIDER="openai"
LLM_MODEL_FAST="gpt-4o-mini"
LLM_MODEL_SMART="gpt-4o"

OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL_FAST="llama3.1:8b"
OLLAMA_MODEL_SMART="qwen2.5:14b"

RATE_LIMIT_PER_IP_PER_HOUR=10
RATE_LIMIT_GLOBAL_PER_DAY=500

# Hard monthly LLM spend cap in USD. Calls throw when the calendar month's
# logged spend meets this. Set 0 to disable. Ollama is always exempt.
LLM_MONTHLY_USD_CAP=20

# Admin basic auth — set both to enable /admin, leave blank to seal it.
ADMIN_USER=""
ADMIN_PASS=""

# Salt for the SHA-256 IP hash used in vote deduplication. Change per deploy.
IP_HASH_SALT="change-me"

# data.gov.in API key (free at https://data.gov.in — Profile → Generate API Key)
DATA_GOV_IN_API_KEY=""
